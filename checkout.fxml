<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ToggleGroup?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.shopping.controllers.CheckoutController"
            styleClass="root-pane">

    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="12">
            <Button text="← Back to Cart"
                    styleClass="btn-outline" onAction="#handleBackToCart" />
            <Label text="💳  Checkout" styleClass="nav-brand" />
        </HBox>
    </top>

    <center>
        <HBox spacing="24" styleClass="content-area">

            <VBox HBox.hgrow="ALWAYS" spacing="20">

                <VBox styleClass="card" spacing="12">
                    <Label text="📦  Shipping Address" styleClass="card-title" />
                    <Separator />
                    <HBox spacing="12">
                        <VBox HBox.hgrow="ALWAYS" spacing="5">
                            <Label text="Full Name" styleClass="field-label" />
                            <TextField fx:id="shipNameField"
                                       styleClass="input-field"
                                       promptText="Your full name" />
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="5">
                            <Label text="Email" styleClass="field-label" />
                            <TextField fx:id="shipEmailField"
                                       styleClass="input-field"
                                       promptText="Email address" />
                        </VBox>
                    </HBox>
                    <Label text="Street Address" styleClass="field-label" />
                    <TextField fx:id="shipAddressField"
                               styleClass="input-field"
                               promptText="House No, Street, Area" />
                    <HBox spacing="12">
                        <VBox HBox.hgrow="ALWAYS" spacing="5">
                            <Label text="City" styleClass="field-label" />
                            <TextField fx:id="shipCityField"
                                       styleClass="input-field"
                                       promptText="City" />
                        </VBox>
                        <VBox spacing="5">
                            <Label text="ZIP Code" styleClass="field-label" />
                            <TextField fx:id="shipZipField"
                                       styleClass="input-field"
                                       prefWidth="110"
                                       promptText="ZIP" />
                        </VBox>
                    </HBox>
                </VBox>

                <VBox styleClass="card" spacing="12">
                    <Label text="💳  Payment Method" styleClass="card-title" />
                    <Separator />
                    <RadioButton fx:id="payCard"
                                 text="💳  Credit / Debit Card"
                                 styleClass="radio-btn"
                                 selected="true" />
                    <RadioButton fx:id="payUpi"
                                 text="📱  UPI / Mobile Wallet"
                                 styleClass="radio-btn" />
                    <RadioButton fx:id="payCod"
                                 text="💵  Cash on Delivery"
                                 styleClass="radio-btn" />
                    <HBox spacing="10">
                        <TextField fx:id="cardField"
                                   promptText="Card number (demo only)"
                                   styleClass="input-field" prefWidth="200" />
                        <TextField fx:id="cvvField"
                                   promptText="CVV"
                                   styleClass="input-field" prefWidth="80" />
                    </HBox>
                </VBox>

            </VBox>

            <VBox styleClass="summary-panel" spacing="14" minWidth="300">
                <Label text="Order Summary" styleClass="section-title" />
                <Separator />
                <ListView fx:id="orderItemsList"
                          styleClass="order-list" prefHeight="240" />
                <Separator />
                <HBox>
                    <Label text="Subtotal:" styleClass="summary-label" />
                    <HBox HBox.hgrow="ALWAYS" />
                    <Label fx:id="checkoutSubtotal" text="$0.00"
                           styleClass="summary-value" />
                </HBox>
                <HBox>
                    <Label text="Shipping:" styleClass="summary-label" />
                    <HBox HBox.hgrow="ALWAYS" />
                    <Label text="FREE" styleClass="summary-value-green" />
                </HBox>
                <Separator />
                <HBox>
                    <Label text="TOTAL:" styleClass="summary-total-label" />
                    <HBox HBox.hgrow="ALWAYS" />
                    <Label fx:id="checkoutTotal" text="$0.00"
                           styleClass="summary-total-value" />
                </HBox>
                <Label fx:id="checkoutError" styleClass="error-label"
                       wrapText="true" text="" />
                <Button text="✅  Place Order"
                        styleClass="btn-success" maxWidth="Infinity"
                        onAction="#handlePlaceOrder" />
            </VBox>

        </HBox>
    </center>

</BorderPane>