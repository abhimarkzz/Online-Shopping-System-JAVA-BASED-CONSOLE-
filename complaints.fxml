<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.shopping.controllers.ComplaintsController"
            styleClass="root-pane">

    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="12">
            <Button text="← Back to Shop"
                    styleClass="btn-outline" onAction="#handleBack" />
            <Label text="💬  Complaints" styleClass="nav-brand" />
        </HBox>
    </top>

    <center>
        <HBox spacing="20" styleClass="content-area">

            <VBox styleClass="card" spacing="14" minWidth="340" maxWidth="360">
                <Label text="Submit a New Complaint" styleClass="card-title" />
                <Separator />

                <Label text="Related Order ID (optional)"
                       styleClass="field-label" />
                <TextField fx:id="orderIdField"
                           promptText="e.g. ORD-1001"
                           styleClass="input-field" />

                <Label text="Subject *" styleClass="field-label" />
                <TextField fx:id="subjectField"
                           promptText="Brief description of issue"
                           styleClass="input-field" />

                <Label text="Description *" styleClass="field-label" />
                <TextArea fx:id="descField"
                          promptText="Describe your issue in detail..."
                          styleClass="input-field"
                          prefHeight="130"
                          wrapText="true" />

                <Label fx:id="submitMsg" styleClass="success-label"
                       wrapText="true" text="" />

                <Button text="📨  Submit Complaint"
                        styleClass="btn-primary" maxWidth="Infinity"
                        onAction="#handleSubmit" />
            </VBox>

            <VBox HBox.hgrow="ALWAYS" spacing="10">
                <Label text="My Complaints" styleClass="section-title" />
                <TableView fx:id="complaintsTable"
                           VBox.vgrow="ALWAYS" styleClass="data-table">
                    <columns>
                        <TableColumn fx:id="colId"
                                     text="Complaint ID" prefWidth="120" />
                        <TableColumn fx:id="colSubject"
                                     text="Subject" prefWidth="220" />
                        <TableColumn fx:id="colOrder"
                                     text="Order ID" prefWidth="110" />
                        <TableColumn fx:id="colStatus"
                                     text="Status" prefWidth="120" />
                        <TableColumn fx:id="colDate"
                                     text="Submitted" prefWidth="160" />
                    </columns>
                </TableView>
            </VBox>

        </HBox>
    </center>

</BorderPane>